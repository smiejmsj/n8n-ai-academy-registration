      "parameters": {
        "jsCode": "let rawText = $input.item.json.output;\nrawText = rawText.replace(/```json|```/g, '').trim();\n\nlet cleanJson = {};\ntry {\n    cleanJson = JSON.parse(rawText);\n} catch (e) {\n    // إذا وقع خطأ في القراءة\n    cleanJson = {};\n}\n\n// هنا الكود غايتأكد من تاريخ انتهاء الاشتراك، وإلا مالقاهش غايحسبو بوحدو\nif (!cleanJson.expiry_date) {\n    let today = new Date(\"2026-07-18\"); // تاريخ اليوم الحالي\n    today.setMonth(today.getMonth() + 1); // زيادة شهر كامل\n    cleanJson.expiry_date = today.toISOString().split('T')[0];\n}\n\nreturn { json: cleanJson };"
      },
